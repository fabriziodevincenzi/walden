---
// src/components/ArticlePreview.astro
import { marked } from 'marked';
import { decode } from 'html-entities';

interface Props {
  article: {
    slug: string;
    body: string;
    data: {
      title: string;
      description: string;
      author: string;
      authorTitle: string;
      authorImage: string;
    };
  };
}

const { article } = Astro.props;
const { title, description, author, authorTitle, authorImage } = article.data;

// Converti il Markdown in HTML
const fullContent = marked.parse(article.body);

// Estrai il testo puro dall'HTML e decodifica le entità HTML
const textContent = decode(fullContent.replace(/<[^>]*>/g, ''));

// Limita il testo a 350 caratteri
const truncatedContent = textContent.slice(0, 420) + (textContent.length > 420 ? '...' : '');
---

<article class="article">
  <h2 class="article-title">
    <a href={`/editoriali/${article.slug}`}>{title}</a>
  </h2>
  <p class="article-description">{description}</p>
  <div class="author-info">
    {authorImage && <img src={authorImage} alt={author} class="author-image"/>}
    <div>
      <p class="author-name">{author}</p>
      <p class="author-title">{authorTitle}</p>
    </div>
  </div>
  <div class="article-content">
    <p>{truncatedContent}</p>
    {textContent.length > 420 && 
      <div class="read-more-container">
        <a href={`/editoriali/${article.slug}`} class="read-more">
          Leggi di più
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    }
  </div>
</article>

<style>
  .article {
    font-family: "DM Sans", sans-serif;
  }

  .article-title {
    font-family: "Fraunces", serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #333;  /* Colore del testo del titolo */
  }

  .article-title a {
    color: inherit;
    text-decoration: none;
  }

  .article-description {
    font-family: "Fraunces", serif;
    font-size: 1rem;
    line-height: 1.5;
    margin-bottom: 1rem;
    font-style: italic;
  }

  .author-info {
    display: flex;
    align-items: center;
    margin-bottom: 1rem;
  }

  .author-image {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    margin-right: 1rem;
    object-fit: cover;
  }

  .author-name {
    font-weight: 600;
    margin: 0;
  }

  .author-title {
    font-size: 0.9rem;
    color: #666;
    margin: 0.2rem 0 0 0;
  }

  .article-content {
    font-size: 1rem;
    line-height: 1.6;
  }

  .read-more-container {
    margin-top: 1rem;
    text-align: right;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    font-family: "Fraunces", serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: #333;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .read-more:hover {
    color: #666;
  }

  .read-more svg {
    margin-left: 0.5rem;
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .read-more:hover svg {
    transform: translateX(5px);
  }
</style>