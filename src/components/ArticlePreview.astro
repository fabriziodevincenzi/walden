---
const { article } = Astro.props;
const { title, pubDate, author, image } = article.data;

const formatDate = (date) => {
  return new Date(date).toLocaleDateString('it-IT', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<section class="featured-article">
  <h3 class="section-title">In evidenza</h3>
  {image && image.url && (
    <div class="article-image">
      <img src={image.url} alt={image.alt || title} />
    </div>
  )}
  <h2 class="article-title">
    <a href={`/articoli/${article.slug}`}>{title}</a>
  </h2>
  <div class="article-meta">
    <span class="article-author">{author}</span>
    <span class="article-date">{formatDate(pubDate)}</span>
  </div>
</section>

<style>
  .featured-article {
    margin-top: 1.5rem;
    padding-top: 0rem;
    border-top: 1px solid #e0e0e0;
  }

  .section-title {
    font-family: "DM Sans", sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #333;
  }

  .article-image {
    margin-bottom: 1rem;
  }

  .article-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .article-title {
    font-family: "Fraunces", serif;
    font-size: 1.8rem;
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .article-title a {
    color: inherit;
    text-decoration: none;
  }

  .article-meta {
    font-family: "DM Sans", sans-serif;
    font-size: 0.9rem;
    color: #666;
  }

  .article-author {
    font-weight: 600;
    margin-right: 0.5rem;
  }
</style>