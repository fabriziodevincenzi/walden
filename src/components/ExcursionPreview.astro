---
// src/components/ExcursionPreview.astro
interface Props {
  excursion: {
    slug: string;
    data: {
      title: string;
      author: string;
      authorTitle: string; // Assicurati che questo sia presente
      image?: {
        url: string;
        alt: string;
      };
      duration?: string;
      difficulty?: string;
      distance?: string;
    };
  };
}

const { excursion } = Astro.props;
const { title, author, authorTitle, image, duration, difficulty, distance } = excursion.data;

---

<article class="article">
  {image && (
    <figure class="article-img">
      <img src={image.url} alt={image.alt} />
    </figure>
  )}
  <div class="article-content">
    <h2 class="article-title">
      <a href={`/escursioni/${excursion.slug}`} class="article-link">{title}</a>
    </h2>
    <div class="article-metadata">
      <p>Durata: {duration}</p>
      <p>Difficoltà: {difficulty}</p>
      <p>Distanza: {distance}</p>
    </div>
    <div class="author-info">
      <p class="author-name">{author}</p>
      <p class="author-title">{authorTitle}</p>
    </div>
  </div>
</article>

<style>
  .article {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
  }

  .article-img {
  width: 100%;
  margin-bottom: 1rem;
  padding: 0 0rem;
  margin-block-start: 1em;
  margin-block-end: 0em;
  margin-inline-start: 0px;
  margin-inline-end: 0px;
}

  .article-img img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 8px;
  }

  .article {
    padding-bottom: 2rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid #e0d8c9;
  }

  .article:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .article-title {
    font-family: "Fraunces", serif;
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.25;
    margin-bottom: 0.5rem;
    color: #333;
  }

  .article-link {
    color: inherit;
    text-decoration: none;
  }

  .article-metadata {
    font-size: 0.95rem;
    color: #666;
    margin-bottom: 0.5rem;
  }

  .article-metadata p {
    margin: 0.1rem 0;
  }

  .author-info {
    margin-top: 1rem;
  }

  .author-name {
    font-weight: 600;
    margin: 0;
  }

  .author-title {
    font-size: 0.9rem;
    color: #666;
    margin: 0.2rem 0 0 0;
  }

  .excursion {
    padding-bottom: 1rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid #e0d8c9;
  }

  .excursion:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
</style>