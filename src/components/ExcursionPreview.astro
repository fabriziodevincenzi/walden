---
const { excursion } = Astro.props;
const { title, pubDate, description, author, image, durata, difficolta } = excursion.data;

const formatDate = (date) => {
  return new Date(date).toLocaleDateString('it-IT', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<article class="article">
  <figure class="article-img">
    {image && <img src={image.url} alt={image.alt} />}
  </figure>
  <h2 class="article-title article-title--small">
    <a href={`/escursioni/${excursion.slug}`} class="article-link">{title}</a>
  </h2>
  <div class="article-excerpt">
    <p>{description}</p>
  </div>
  <div class="article-creditation">
    <p>Guida: {author}</p>
    {durata && <p>Durata: {durata}</p>}
    {difficolta && <p>Difficoltà: {difficolta}</p>}
  </div>
</article>

<style>
  .article {
    margin-top: 1rem;
    margin-bottom: 1rem;
  }
  
  .article-img {
    margin: 0;
    padding: 0;
    width: 100%;
  }
  .article-img img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }
  .article-title {
    font-family: "Fraunces", serif;
    font-weight: 900;
    line-height: 1.25;
    color: #000;
    margin-top: 1rem;
    margin-bottom: 0.75rem;
  }
  .article-title--small {
    font-size: 1.25rem;
  }
  .article-link {
    color: inherit;
    text-decoration: none;
  }
  .article-excerpt {
    font-size: 1.125rem;
    line-height: 1.4;
    margin-bottom: 1rem;
  }
  .article-creditation {
    font-size: 0.875rem;
    color: #666;
  }
  .article-creditation p {
    margin: 0.25rem 0;
  }
</style>