---
const { editorial } = Astro.props;
const { title, pubDate, description, author, authorImage } = editorial.data;

const formatDate = (date) => {
  return new Date(date).toLocaleDateString('it-IT', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<article class="article">
  <h2 class="article-title article-title--large">
    <a href={`/editoriali/${editorial.slug}`} class="article-link">{title}</a>
  </h2>
  <div class="article-date">
    {formatDate(pubDate)}
  </div>
  <div class="article-excerpt">
    <p>{description}</p>
  </div>
  <div class="article-author">
    <div class="article-author-img">
      {authorImage ? 
        <img src={authorImage.url} alt={`Foto di ${author}`} /> :
        <img src="/images/author-placeholder.png" alt={author} />
      }
    </div>
    <div class="article-author-info">
      <dl>
        <dt>{author}</dt>
        <dd>Editorialista</dd>
      </dl>
    </div>
  </div>
</article>

<style>
  .article {
    margin-top: 0rem;
    margin-bottom: 0rem;
  }
  .article-title {
    font-family: "Fraunces", serif;
    font-weight: 900;
    line-height: 1.25;
    color: #000;
    margin-bottom: 0.5rem;
  }
  .article-title--large {
    font-size: 2rem;
  }
  .article-link {
    color: inherit;
    text-decoration: none;
  }
  .article-date {
    font-size: 0.9rem;
    color: #666;
    margin-bottom: 1rem;
  }
  .article-excerpt {
    font-size: 1.125rem;
    line-height: 1.4;
    margin-bottom: 1rem;
  }
  .article-author {
    display: flex;
    align-items: center;
  }
  .article-author-img {
    width: 3rem;
    height: 3rem;
    border-radius: 12px;
    overflow: hidden;
    margin-right: 0.5rem;
  }
  .article-author-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .article-author-info dl {
    margin: 0;
  }
  .article-author-info dt {
    font-weight: 600;
  }
  .article-author-info dd {
    font-size: 0.875em;
    margin: 0;
  }
</style>