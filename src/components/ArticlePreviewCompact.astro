---
const { article, isLast } = Astro.props;
const { title, pubDate } = article.data;

const formatDate = (date) => {
  return new Date(date).toLocaleDateString('it-IT', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<article class={`article-compact ${isLast ? 'last-article' : ''}`}>
  <h3 class="article-title">
    <a href={`/articoli/${article.slug}`}>{title}</a>
  </h3>
  <div class="article-meta">
    <span class="article-date">{formatDate(pubDate)}</span>
  </div>
</article>

<style>
  .article-compact {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e0e0e0;
  }

  .article-compact.last-article {
    border-bottom: none;
    padding-bottom: 0;
  }

  .article-title {
    font-family: "DM Sans", sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .article-title a {
    color: inherit;
    text-decoration: none;
  }

  .article-meta {
    font-size: 0.9rem;
    color: #666;
  }
</style>