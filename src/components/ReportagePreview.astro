---
const { reportage } = Astro.props;
const { title, pubDate, description, author, image, authorImage } = reportage.data;

const formatDate = (date) => {
  return new Date(date).toLocaleDateString('it-IT', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<article class="article">
  <figure class="article-img">
    {image && <img src={image.url} alt={image.alt} />}
  </figure>
  <h2 class="article-title article-title--medium">
    <a href={`/reportage/${reportage.slug}`} class="article-link">{title}</a>
  </h2>
  <div class="article-excerpt">
    <p>{description}</p>
  </div>
  <div class="article-author">
    <div class="article-author-img">
      {authorImage ? 
        <img src={authorImage.url} alt={`Foto di ${author}`} /> :
        <img src="/images/author-placeholder.png" alt={author} />
      }
    </div>
    <div class="article-author-info">
      <dl>
        <dt>{author}</dt>
        <dd>Reporter</dd>
      </dl>
    </div>
  </div>
</article>

<style>
  .article {
    margin-top: 1rem;
    margin-bottom: 2rem;
  }
  .article-img {
    margin: 0;
    padding: 0;
    width: 100%;
  }
  .article-img img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }
  .article-title {
    font-family: "Fraunces", serif;
    font-weight: 900;
    line-height: 1.25;
    color: #000;
    margin-top: 1rem;
    margin-bottom: 0.75rem;
  }
  .article-title--medium {
    font-size: 1.5rem;
  }
  .article-link {
    color: inherit;
    text-decoration: none;
  }
  .article-excerpt {
    font-size: 1.125rem;
    line-height: 1.4;
    margin-bottom: 1rem;
  }
  .article-author {
    display: flex;
    align-items: center;
  }
  .article-author-img {
    width: 3rem;
    height: 3rem;
    border-radius: 12px;
    overflow: hidden;
    margin-right: 0.5rem;
  }
  .article-author-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .article-author-info dl {
    margin: 0;
  }
  .article-author-info dt {
    font-weight: 600;
  }
  .article-author-info dd {
    font-size: 0.875em;
    margin: 0;
  }
</style>

