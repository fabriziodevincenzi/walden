---
// src/components/ReportagePreview.astro

interface Props {
  reportage: {
    slug: string;
    data: {
      title: string;
      description: string;
      author: string;
      authorTitle: string;
      image?: {
        url: string;
        alt: string;
      };
    };
  };
}

const { reportage } = Astro.props;
const { title, description, author, authorTitle, image } = reportage.data;
---

<article class="article">
  {image && (
    <figure class="article-img">
      <img src={image.url} alt={image.alt} />
    </figure>
  )}
  <h2 class="article-title article-title--large">
    <a href={`/reportage/${reportage.slug}`} class="article-link">{title}</a>
  </h2>
  <div class="article-excerpt">
    <p>{description}</p>
  </div>
  <div class="article-author">
    <div class="author-info">
      <p class="author-name">{author}</p>
      <p class="author-title">{authorTitle}</p>
    </div>
  </div>
</article>

<style>
  .article {
    margin-bottom: 2rem;
  }

  .article-img {
    margin-bottom: 1rem;
    display: block;
    margin-block-start: 1em;
    margin-block-end: 1em;
    margin-inline-start: 0px;
    margin-inline-end: 0px;
    unicode-bidi: isolate;
  }

  .article-img img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 8px;
  }

  .article-title {
    font-family: "Fraunces", serif;
    font-weight: 700;
    line-height: 2.8rem;
    margin-bottom: 0rem;
  }

  .article-title--large {
    font-size: 1.5rem;
    display: block;
    font-size: 2.5em;
    margin-block-start: 0em;
    margin-block-end: 0em;
    margin-inline-start: 0px;
    margin-inline-end: 0px;
    font-weight: bold;
    unicode-bidi: isolate;
  }

  .article-link {
    color: inherit;
    text-decoration: none;
  }

  .article-excerpt {
    font-size: 1rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .article-author-info {
    display: flex;
    flex-direction: column;
  }

  .author-info {
    margin-top: 1rem;
  }
  
  .author-name {
    font-weight: 600;
    margin: 0;
  }

  .author-title {
    font-size: 0.9rem;
    color: #666;
    margin: 0.2rem 0 0 0;
  }

  h2 {
    display: block;
    font-size: 2.5em;
    margin-block-start: 0.83em;
    margin-block-end: 0.83em;
    margin-inline-start: 0px;
    margin-inline-end: 0px;
    font-weight: bold;
    unicode-bidi: isolate;
  }

    /* Assicurati che il contenuto riempia l'intera larghezza disponibile */
    .article, .reportage, .excursion, .media-item {
    width: 100%;
  }

</style>